{
  "name": "PixelWidget",
  "version": "1.0.0",
  "description": "Your Figma widget",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:ui": "node scripts/build.mjs --ui-only",
    "watch": "node scripts/build.mjs --watch",
    "pretypecheck": "npm run build:ui",
    "typecheck": "tsc --noEmit -p widget-src && tsc --noEmit -p ui-src",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@figma/widget-typings": "*",
    "esbuild": "*",
    "eslint": "^9.39.4",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
